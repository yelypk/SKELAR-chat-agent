# ---- LLM provider ----
LLM_PROVIDER=ollama

# ---- Ollama ----
OLLAMA_BASE_URL=http://localhost:11434

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ---- Models ----
SUPPORT_MODEL=qwen3:30b-thinking
CUSTOMER_MODEL=qwen3:30b-thinking
JUDGE_MODEL=qwen3:30b-thinking
EMBEDDING_MODEL=nomic-embed-text

# ---- Redis (docker-compose) ----
REDIS_URL=redis://localhost:6379/0

# ---- Postgres (docker-compose) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=skelar_chat_agent
# For SQLAlchemy app runtime (psycopg driver):
POSTGRES_DSN=postgresql+psycopg://app:app@localhost:5432/skelar_chat_agent
# For external tools (TablePlus, DBeaver, psql URI):
POSTGRES_TABLEPLUS_URL=postgresql://app:app@localhost:5432/skelar_chat_agent

# ---- Optional Postgres+pgvector (docker-compose profile: pgvector) ----
PGVECTOR_POSTGRES_PORT=5433
PGVECTOR_POSTGRES_DSN=postgresql+psycopg://app:app@localhost:5433/skelar_chat_agent

# ---- App ----
DATASET_OUTPUT_DIR=dataset_outputs
MAX_TURNS=40
DEADLOCK_WINDOW=3
DEADLOCK_SIMILARITY_THRESHOLD=0.92
RETRIES_PER_LLM_CALL=2
LLM_TIMEOUT_SECONDS=180
