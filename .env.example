# ---- LLM (Ollama runs locally on Windows) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---- Redis (docker-compose) ----
REDIS_URL=redis://localhost:6379/0

# ---- Postgres (docker-compose) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=skelar_chat_agent
POSTGRES_DSN=postgresql://app:app@localhost:5432/skelar_chat_agent

# ---- Optional Postgres+pgvector (docker-compose profile: pgvector) ----
PGVECTOR_POSTGRES_PORT=5433
PGVECTOR_POSTGRES_DSN=postgresql://app:app@localhost:5433/skelar_chat_agent

# ---- App ----
DATASET_OUTPUT_DIR=dataset_outputs
MAX_TURNS=12
